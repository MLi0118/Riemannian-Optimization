def main():
    print(f"[setup] device = {DEVICE}")
    print(f"[setup] seed = {SEED}")
    print(f"[setup] QUICK_MODE = {QUICK_MODE}  "
          f"(T_OUTER={T_OUTER}, M_TASKS={M_TASKS})")
    print(f"[setup] methods = {METHODS}")
    print(f"[setup] regimes = {REGIMES}")

    cache = build_or_load_cache(DATA_ROOT, CACHE_PATH)

    classes = sorted(cache.keys())
    if len(classes) < 100:
        print(f"WARNING: only {len(classes)} classes in cache "
              f"(MiniImageNet expects 100); continuing anyway.")

    train_classes, val_classes, test_classes = split_classes(classes, seed=SEED)
    print(f"[setup] train/val/test class split: "
          f"{len(train_classes)}/{len(val_classes)}/{len(test_classes)}")

    traces = []
    n_runs = sum(1 for r in REGIMES if r in LAMBDA_REGIMES) * len(METHODS)
    run_idx = 0
    for regime in REGIMES:
        if regime not in LAMBDA_REGIMES:
            print(f"  skipping unknown regime: {regime}")
            continue
        lam = LAMBDA_REGIMES[regime]
        for method in METHODS:
            if method not in ALL_METHODS:
                print(f"  skipping unknown method: {method}")
                continue
            run_idx += 1
            print(f"\n[run {run_idx}/{n_runs}]")
            tr = run(method, lam, regime, cache, train_classes)
            traces.append(tr)
            # Save intermediate JSON after each run
            out_json = RESULTS_DIR / f"trace_{regime}_{method}.json"
            with open(out_json, "w") as f:
                json.dump(tr, f, indent=2)

    # Aggregate plot
    plot_results(traces, RESULTS_DIR / "comparison.png")

    # Summary print
    print("\n=== Final-step summary ===")
    print(f"{'regime':<16} {'method':<12} {'steps':>6} {'q_loss':>10} "
          f"{'q_acc':>8} {'||g||^2':>12} {'||g_canon||^2':>14} "
          f"{'v_rel_err':>11} {'ker H':>7}")
    for tr in traces:
        if len(tr["step"]) == 0:
            print(f"{tr['regime']:<16} {tr['method']:<12} {0:>6} "
                  f"{'(diverged at step 0)':>40}")
            continue
        n_steps = len(tr["step"])
        diverged = " *" if n_steps < T_OUTER else ""
        v_err = tr["v_rel_err"][-1]
        v_err_s = f"{v_err:>11.2e}" if (v_err is not None and np.isfinite(v_err)) else f"{'nan':>11}"
        print(f"{tr['regime']:<16} {tr['method']:<12} {n_steps:>6} "
              f"{tr['q_loss'][-1]:>10.4f} {tr['q_acc'][-1]:>8.3f} "
              f"{tr['grad_norm_sq'][-1]:>12.3e} "
              f"{tr['canon_grad_norm_sq'][-1]:>14.3e} "
              f"{v_err_s} {tr['n_kernel'][-1]:>7.0f}"
              f"{diverged}")
    print("(* = aborted before T_OUTER due to divergence; "
          "see trace_*.json for the partial trajectory)")


if __name__ == "__main__":
